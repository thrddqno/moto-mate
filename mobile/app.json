{
  "expo": {
    "name": "Moto Mate",
    "slug": "moto-mate",
    "scheme": "motomate",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.thrddqno.motomate"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-web-browser",
      [
        "expo-font",
        {
          "fonts": [
            "node_modules/@expo-google-fonts/audiowide/Audiowide_400Regular.ttf",
            "node_modules/@expo-google-fonts/karla/Karla_400Regular.ttf",
            "node_modules/@expo-google-fonts/karla/Karla_500Medium.ttf",
            "node_modules/@expo-google-fonts/karla/Karla_600SemiBold.ttf",
            "node_modules/@expo-google-fonts/karla/Karla_700Bold.ttf",
            "node_modules/@expo-google-fonts/jetbrains-mono/JetBrainsMono_400Regular.ttf",
            "node_modules/@expo-google-fonts/jetbrains-mono/JetBrainsMono_500Medium.ttf",
            "node_modules/@expo-google-fonts/jetbrains-mono/JetBrainsMono_700Bold.ttf"
          ]
        }
      ]
    ]
  }
}
